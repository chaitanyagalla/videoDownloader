# Server
PORT=4000
NODE_ENV=development

# Database (Neon PostgreSQL)
# Example: postgresql://USER:PASSWORD@ep-example.us-east-1.aws.neon.tech/videosave?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/videosave?sslmode=require"

# CORS - frontend URL
FRONTEND_URL=http://localhost:3000

# Google OAuth
# Create credentials in Google Cloud Console and use:
# http://localhost:4000/api/auth/google/callback
# as the local authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Auth session cookie
AUTH_COOKIE_NAME=videosave_session
AUTH_SESSION_DAYS=30

# yt-dlp binary path
# Use "yt-dlp" if it's in your PATH, or provide the full path:
# Windows example: C:\Users\YourName\AppData\Local\Programs\yt-dlp\yt-dlp.exe
# macOS/Linux example: /usr/local/bin/yt-dlp
YTDLP_PATH=yt-dlp
FFMPEG_LOCATION=
DOWNLOADS_DIR=./downloads
MAX_CONCURRENT_DOWNLOADS=2
MAX_DOWNLOAD_FILESIZE_MB=500
MAX_VIDEO_DURATION_SECONDS=3600
DOWNLOAD_TIMEOUT_MS=900000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20
DOWNLOAD_RATE_LIMIT_MAX=5

# Set to 1 only when deployed behind one trusted reverse proxy/load balancer.
TRUST_PROXY_HOPS=0

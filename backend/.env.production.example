PORT=4000
NODE_ENV=production

DATABASE_URL="postgresql://USER:PASSWORD@HOST/videosave?sslmode=require"
FRONTEND_URL=https://your-frontend-domain.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/api/auth/google/callback

AUTH_COOKIE_NAME=videosave_session
AUTH_SESSION_DAYS=30

YTDLP_PATH=/opt/yt-dlp/bin/yt-dlp
# Netscape-format YouTube cookie export. In Docker this path is provided by the
# volume mount in docker-compose.yml, so leave it commented here and let compose
# inject it. Required to avoid YouTube's bot-detection on server IPs.
# YTDLP_COOKIES_FILE=/run/secrets/youtube-cookies.txt
YTDLP_COOKIES_FROM_BROWSER=
# Optional proxy fallback for when the server IP is flagged by YouTube.
# Examples: http://user:pass@host:port  or  socks5://host:port
YTDLP_PROXY=
FFMPEG_LOCATION=/usr/bin/ffmpeg
DOWNLOADS_DIR=/tmp/videosave-downloads
MAX_CONCURRENT_DOWNLOADS=1
MAX_DOWNLOAD_FILESIZE_MB=300
MAX_VIDEO_DURATION_SECONDS=1800
DOWNLOAD_TIMEOUT_MS=900000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20
DOWNLOAD_RATE_LIMIT_MAX=5
TRUST_PROXY_HOPS=1
